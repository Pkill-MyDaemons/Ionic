// Math operations demo

fn factorial(int64 n) -> int64 {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

fn fibonacci(int64 n) -> int64 {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

let n = 10;
let fact = factorial(n);
print(fact);

let fib = fibonacci(10);
print(fib);

// Loop demo
mut i = 0;
while (i < 5) {
    print(i);
    i = i + 1;
}

// For loop
for (j in 0..5) {
    print(j);
}
