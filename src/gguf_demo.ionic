// GGUF LLM inference demo — runs any Ollama GGUF model directly (no Ollama server needed).
//
// Usage:
//   ./target/release/ionic src/gguf_demo.ionic -o /tmp/gguf_demo
//   /tmp/gguf_demo <path-to.gguf> "your prompt here" [max_tokens]
//
// Example with Ollama's gemma3:1b blob:
//   /tmp/gguf_demo \
//     ~/.ollama/models/blobs/sha256-7cd4618c1faf8b7233c6c906dac1694b6a47684b37b8895d470ac688520b9c01 \
//     "Explain what a tensor is in one sentence." 128

fn main() -> int64 {
    let model_path = get_arg(0);
    let prompt     = get_arg(1);
    let max_tokens = 256;

    // Load model — llama.cpp auto-enables Metal GPU layers
    let mdl = load_model(model_path);

    // Optional: tune sampling
    gguf_set_temp(mdl, 0.7);
    gguf_set_top_p(mdl, 0.9);

    print("=== Ionic GGUF Inference ===");
    print("Prompt: ");
    print(prompt);
    print("--- Response ---");

    let response = gguf_generate(mdl, prompt, max_tokens);
    print(response);

    model_free(mdl);
    return 0;
}
